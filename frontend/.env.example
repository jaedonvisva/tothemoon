# Copy to .env.local

# Moonshot Bun API (Path A: Privy auth). Default dev port 3001 when Next uses 3000.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Same Privy App ID as backend PRIVY_APP_ID (public).
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: Supabase for demos / Postgres hosting only — not used for Moonshot API auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
