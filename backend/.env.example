# Server — use 3001 when Next.js runs on 3000 (see frontend .env.example)
PORT=3001
NODE_ENV=development

# Database
# Supabase: Settings → Database → use the direct URI (host db.<ref>.supabase.co, port 5432). Add ?sslmode=require if needed.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Local Docker (see docker-compose.yml):
# DATABASE_URL="postgresql://moonshot:moonshot@localhost:5432/moonshot"

# Redis (local: redis://localhost:6379 — or Upstash/Railway URL)
REDIS_URL="redis://localhost:6379"

# Privy (dashboard → App settings) — allowed origins must include FRONTEND_URL
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_10=""
STRIPE_PRICE_ID_25=""
STRIPE_PRICE_ID_50=""

# Frontend origin (Stripe redirects, CORS is open but checkout uses this)
FRONTEND_URL="http://localhost:3000"

# Pyth
PYTH_WS_URL="wss://hermes.pyth.network/ws"

# Game
STARTING_BALANCE=1000
REAL_MAX_LEVERAGE=50
